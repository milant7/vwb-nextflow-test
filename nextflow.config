// Default parameters
params {
    input_text = "Hello from VWB subworkflow test"
    outdir     = "results"
    max_cpus   = 4
    max_memory = "8.GB"
    max_time   = "2.h"
    debug_mode = false
}

// Process defaults
process {
    cpus   = params.max_cpus
    memory = params.max_memory
    time   = params.max_time
}
